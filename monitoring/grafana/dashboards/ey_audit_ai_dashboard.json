{
  "title": "EY Audit AI Workflow Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Workflow Runs",
      "targets": [
        {
          "expr": "sum(rate(workflow_runs_total[5m])) by (status)"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Agent Latency p95",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_latency_seconds_bucket[5m])) by (le, agent))"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "bargauge",
      "title": "Approval Routes",
      "targets": [
        {
          "expr": "sum(approval_routes_total) by (route)"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      }
    }
  ]
}