APP_NAME=EY AI Enterprise Audit & Invoice Compliance Platform
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./outputs/ey_audit_ai.db
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
VECTOR_INDEX_PATH=./outputs/vector_index.json
POLICY_DOCS_PATH=./data/policies
EVIDENCE_OUTPUT_DIR=./outputs/evidence
ENABLE_AZURE_FORM_RECOGNIZER=false
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=
ENABLE_OPENAI_LLM=false
OPENAI_API_KEY=
LANGSMITH_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true
RISK_APPROVAL_THRESHOLD=0.70
HIGH_VALUE_INVOICE_THRESHOLD=25000
AMOUNT_TOLERANCE_PERCENT=2.0
